{
  "uid": "usgs-quakes",
  "title": "USGS Earthquakes — last 30 days",
  "tags": ["spark-demo", "usgs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": {"from": "now-30d", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total events",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT total_events FROM summary", "queryText": "SELECT total_events FROM summary", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Max magnitude",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT max_mag FROM summary", "queryText": "SELECT max_mag FROM summary", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "textMode": "auto"},
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 6.5}]}, "unit": "none"}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg magnitude",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT avg_mag FROM summary", "queryText": "SELECT avg_mag FROM summary", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg depth (km)",
      "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT avg_depth_km FROM summary", "queryText": "SELECT avg_depth_km FROM summary", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Distinct regions",
      "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT distinct_regions FROM summary", "queryText": "SELECT distinct_regions FROM summary", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}
    },
    {
      "id": 6,
      "type": "barchart",
      "title": "Earthquakes per day",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 9},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT day, count FROM daily_counts ORDER BY day", "queryText": "SELECT day, count FROM daily_counts ORDER BY day", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"xTickLabelRotation": 45, "xTickLabelSpacing": 0, "showValue": "never", "stacking": "none", "groupWidth": 0.7, "barWidth": 0.9, "orientation": "auto", "legend": {"showLegend": false, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Magnitude distribution (integer bucket)",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 9},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT bucket, count FROM mag_buckets ORDER BY bucket", "queryText": "SELECT bucket, count FROM mag_buckets ORDER BY bucket", "timeColumns": [], "queryType": "table"}
      ],
      "options": {"xTickLabelRotation": 0, "showValue": "auto", "stacking": "none", "groupWidth": 0.7, "barWidth": 0.9, "orientation": "auto", "legend": {"showLegend": false, "displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top 10 strongest",
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 9},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT time_utc, mag, depth, place FROM top_strongest ORDER BY mag DESC", "queryText": "SELECT time_utc, mag, depth, place FROM top_strongest ORDER BY mag DESC", "timeColumns": [], "queryType": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}}}, "overrides": []},
      "options": {"showHeader": true, "cellHeight": "sm", "footer": {"show": false, "countRows": false, "reducer": ["sum"], "fields": ""}}
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top 10 regions by count",
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 9},
      "datasource": {"type": "frser-sqlite-datasource", "uid": "quakes-ds"},
      "targets": [
        {"refId": "A", "rawQueryText": "SELECT region, count, max_mag FROM top_places ORDER BY count DESC", "queryText": "SELECT region, count, max_mag FROM top_places ORDER BY count DESC", "timeColumns": [], "queryType": "table"}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}}}, "overrides": []},
      "options": {"showHeader": true, "cellHeight": "sm", "footer": {"show": false, "countRows": false, "reducer": ["sum"], "fields": ""}}
    }
  ]
}
